model Payment {
    id                 String        @id @default(uuid(7))
    amount             Float
    transactionId      String        @unique @db.Uuid()
    stripeEventId      String?       @unique
    status             PaymentStatus @default(UNPAID)
    paymentGatewayData Json?
    createdAt          DateTime      @default(now())
    updatedAt          DateTime      @updatedAt
    purpose            String? // TICKET_PURCHASE, SUBSCRIPTION_PURCHASE, SUBSCRIPTION_RENEWAL

    viewerId String
    viewer   Viewer @relation(fields: [viewerId], references: [id], onDelete: Cascade)

    ticketId       String?       @unique
    ticket         Ticket?       @relation(fields: [ticketId], references: [id], onDelete: Cascade)
    // One-to-many relationship with Subscription
    subscriptionId String?
    subscription   Subscription? @relation(fields: [subscriptionId], references: [id])

    @@index([viewerId])
    @@index([transactionId])
    @@index([status])
    @@map("payments")
}
